generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AgentVisit {
  id              String   @id @default(cuid())
  agentCardId     String   // BusinessCard.id of the agent
  leadId          String?  // If visit is linked to a specific lead
  latitude        Float
  longitude       Float
  locationAddress String?
  locationLabel   String?  // e.g., "Shell Petrol Station, Westlands"
  visitNote       String?
  durationMins    Int?
  outcome         String   @default("VISITED") // "VISITED", "NO_ANSWER", "FOLLOW_UP", "CONVERTED"
  photos          String[] @default([]) // Supabase storage URLs
  createdAt       DateTime @default(now())
}

model FieldPhoto {
  id          String   @id @default(cuid())
  agentCardId String
  leadId      String?
  visitId     String?
  photoUrl    String
  caption     String?
  type        String   @default("STOREFRONT") // "STOREFRONT", "DOCUMENT", "RECEIPT", "OTHER"
  latitude    Float?
  longitude   Float?
  createdAt   DateTime @default(now())
}

model FieldAccount {
  id              String   @id @default(cuid())
  name            String
  address         String?
  latitude        Float
  longitude       Float
  
  // Sales specific fields
  status          String   @default("PROSPECT") // PROSPECT, CUSTOMER, CHURNED
  salesStage      String   @default("NEW") // NEW, QUALIFIED, NEGOTIATING, CLOSED_WON
  salesYTD        Float    @default(0)
  nextStep        String?  // e.g. "phone call", "drop off a sample"
  nextStepDate    DateTime?
  daysSinceVisit  Int      @default(0)
  priority        String   @default("Medium") // High, Medium, Low
  
  // Organization / Agent mapping
  agentCardId     String?  // ID of the assigned field rep
  orgId           String?  // ID of the organization
  
  customFields    Json?    // For flexibility (Specialty, Customer Type, etc.)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  role          String    @default("USER") // USER, BUSINESS_OWNER, ADMIN
  accounts      Account[]
  sessions      Session[]
  business      Business?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Business {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String
  description String?
  latitude    Float?
  longitude   Float?
  address     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
