# JijiPoll Environment Variables
# Copy this to .env.local and fill in your values

# Database
DATABASE_URL="postgresql://user:password@host:5432/jijipoll"

# NextAuth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3001"

# Optional: Shared with StampKE if using same DB
# You can point DATABASE_URL to the same Supabase DB as StampKE
